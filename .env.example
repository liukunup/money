# .env.example
# 应用配置
APP_NAME=Money
APP_VERSION=0.1.0
DEBUG=True

# 数据库配置
DATABASE_TYPE=sqlite
DATABASE_URL=sqlite:///./data/money.db

# 安全配置
SECRET_KEY=change-this-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# CORS 配置
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:8080
